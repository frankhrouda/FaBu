# Copy this file to backend/.env for local development
# cp backend/.env.example backend/.env

# JWT
JWT_SECRET=change-this-local-dev-secret

# Datenbank: "sqlite" (Standard, kein Setup) oder "postgres"
DB_CLIENT=sqlite

# Nur nötig wenn DB_CLIENT=postgres
# Lokal einrichten mit: ./setup-postgres.sh
DATABASE_URL=postgresql://fabu:fabu_local_pw@localhost:5432/fabu
