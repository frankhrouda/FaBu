#!/usr/bin/env bash
set -euo pipefail

if git diff --cached --name-only | grep -Eq '^(backend/src/version.js|frontend/src/version.js)$'; then
  echo "[version] version files already staged - skipping auto bump"
  exit 0
fi

node scripts/bump-app-versions.mjs
git add backend/src/version.js frontend/src/version.js
