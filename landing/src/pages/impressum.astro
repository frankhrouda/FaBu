---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Impressum | FaBu" description="Impressum der FaBu Landing-Page.">
  <main class="mx-auto max-w-3xl px-6 py-16">
    <a href="/" class="text-sm font-bold text-pine hover:underline">Zuruck zur Startseite</a>
    <h1 class="mt-4 font-display text-4xl font-bold">Impressum</h1>
    <div class="mt-8 rounded-2xl border border-ink/10 bg-white/80 p-6 shadow-card">
      <p class="text-sm text-ink/80">
        Bitte hinterlege hier die rechtlich erforderlichen Angaben (Firma, Vertretungsberechtigte,
        Kontakt, Handelsregister, USt-ID falls vorhanden).
      </p>
    </div>
  </main>
</BaseLayout>
